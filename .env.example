# Root .env used by docker-compose

# Postgres
POSTGRES_USER=ioms
POSTGRES_PASSWORD=ioms_password
POSTGRES_DB=ioms

# Backend
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend (build-time)
VITE_API_URL=http://localhost:8000/api
