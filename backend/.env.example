# development | production
# In production the app refuses to start with an insecure SECRET_KEY and hides /docs.
ENVIRONMENT=development
# Set to true to expose Swagger /docs even in production.
ENABLE_DOCS=false

# PostgreSQL connection (psycopg v3 driver)
DATABASE_URL=postgresql+psycopg://ioms:ioms_password@localhost:5432/ioms

# JWT
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (JSON array of allowed origins)
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# First admin user created on startup (optional)
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=admin12345
FIRST_ADMIN_NAME=Administrator
